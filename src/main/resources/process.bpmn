  <bpmn:process id="springboot-camunda-lafayette-process" name="camunda-lafayette" isExecutable="true" camunda:versionTag="v3">
    <bpmn:startEvent id="StartEvent_1" name="Lafayette want  to be involed in a Revolution">
      <bpmn:outgoing>SequenceFlow_1fp17al</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:sequenceFlow id="SequenceFlow_1fp17al" sourceRef="StartEvent_1" targetRef="say-hello" />
    <bpmn:userTask id="say-hello" name="Prepare for Departure" camunda:formKey="camunda-forms:/forms/prepere_for_departure.form" camunda:candidateUsers="demo">
      <bpmn:extensionElements />
      <bpmn:incoming>SequenceFlow_1fp17al</bpmn:incoming>
      <bpmn:outgoing>Flow_1284jbf</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_1284jbf" sourceRef="say-hello" targetRef="Gateway_0o4sgau" />
    <bpmn:userTask id="Activity_1ff6m1e" name="Get a Taxi" camunda:formKey="camunda-forms:/forms/get_taxi.form">
      <bpmn:incoming>Flow_0q04z4d</bpmn:incoming>
      <bpmn:outgoing>Flow_10helgl</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_10helgl" sourceRef="Activity_1ff6m1e" targetRef="Gateway_1levyrb" />
    <bpmn:userTask id="Activity_0osx7a6" name="Overthrow the monarchy">
      <bpmn:incoming>Flow_1wzbthv</bpmn:incoming>
      <bpmn:outgoing>Flow_05315ek</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="Event_06d85nw" name="Lafayette has helped a revolution">
      <bpmn:incoming>Flow_05315ek</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_05315ek" sourceRef="Activity_0osx7a6" targetRef="Event_06d85nw" />
    <bpmn:exclusiveGateway id="Gateway_0o4sgau" name="Where are you going?">
      <bpmn:incoming>Flow_1284jbf</bpmn:incoming>
      <bpmn:outgoing>Flow_0q04z4d</bpmn:outgoing>
      <bpmn:outgoing>Flow_1jtyds6</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_0q04z4d" name="France" sourceRef="Gateway_0o4sgau" targetRef="Activity_1ff6m1e">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{country== 'France'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1jtyds6" name="America" sourceRef="Gateway_0o4sgau" targetRef="Activity_0ogzubo" camunda:delegateExpression="#{reserveSeatOnBoatError}">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">#{country== 'America'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="Gateway_1levyrb">
      <bpmn:incoming>Flow_02v6dhr</bpmn:incoming>
      <bpmn:incoming>Flow_10helgl</bpmn:incoming>
      <bpmn:outgoing>Flow_1wzbthv</bpmn:outgoing>
    </bpmn:exclusiveGateway>
