        <camunda:executionListener delegateExpression="#{reserveSeatOnBoatError}" event="start" />
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1jtyds6</bpmn:incoming>
      <bpmn:outgoing>Flow_02v6dhr</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Activity_1c5gmjo" name="Prepare for a funeral">
