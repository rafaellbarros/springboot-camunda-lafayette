    <bpmn:sequenceFlow id="Flow_1qk6z9r" sourceRef="Activity_1c5gmjo" targetRef="Event_0cx8myl" />
    <bpmn:serviceTask id="Activity_0ogzubo" name="Book a place on ship" camunda:delegateExpression="#{reserveSeatOnBoatError}">
